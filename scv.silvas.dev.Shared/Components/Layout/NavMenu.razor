@using scv.silvas.dev.Shared.Services
@inject UserService UserService
@inject NavigationManager Nav

<nav class="nav-sidebar">
    <div class="nav-brand">
        <span class="nav-brand-text">SCV</span>
    </div>
    <div class="nav-links">
        <NavLink class="nav-item" href="/dashboard" Match="NavLinkMatch.All">
            <span class="nav-icon">&#x2302;</span>
            <span>Dashboard</span>
        </NavLink>
        <NavLink class="nav-item" href="/timeentry">
            <span class="nav-icon">&#x2B;</span>
