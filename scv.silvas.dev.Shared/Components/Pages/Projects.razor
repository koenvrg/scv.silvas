@page "/projects"
@using scv.silvas.dev.Shared.Models
@using scv.silvas.dev.Shared.Services
@inject ProjectService ProjectService
@inject ClientService ClientService
@inject UserService UserService
@inject NavigationManager Nav
@implements IDisposable

<div class="page-container">
    <div class="page-header">
        <h2>Projecten</h2>
    </div>

    @if (_loading)
    {
        <div class="loading">Laden...</div>
    }
    else
    {
        @if (_isAdmin)
        {
            <div class="card form-card">
                <div class="section-title" style="margin-top:0;">Nieuw project aanmaken</div>

                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="alert @(_isError ? "alert-error" : "alert-success")">@_message</div>
                }

                <div class="form-group">
                    <label>Projectnaam</label>
                    <input type="text" @bind="_newName" class="form-control" placeholder="Naam van het project" />
                </div>
                <div class="form-group">
                    <label>Omschrijving</label>
                    <textarea @bind="_newDescription" rows="2" class="form-control" placeholder="Korte omschrijving..."></textarea>
                </div>
                <div class="form-group">
                    <label>Klant</label>
                    <select @bind="_newClientId" class="form-control">
                        <option value="0">Selecteer klant...</option>
                        @foreach (var c in _clients)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Startdatum</label>
                    <input type="date" @bind="_newStartDate" class="form-control" />
                </div>
                <button class="btn btn-primary btn-full" @onclick="CreateProject" disabled="@_saving">
                    @(_saving ? "Aanmaken..." : "Project aanmaken")
                </button>
            </div>
        }

        <h3 class="section-title">Alle projecten</h3>

        @if (!_projects.Any())
        {
            <p class="empty-text">Geen projecten gevonden</p>
        }

        @foreach (var project in _projects)
        {
            var client = _clients.FirstOrDefault(c => c.Id == project.ClientId);

            <div class="card project-card">
                @if (_editingId == project.Id)
                {
                    <div class="section-title" style="margin-top:0;margin-bottom:12px;">Project bewerken</div>
                    <div class="form-group">
                        <label>Projectnaam</label>
                        <input type="text" @bind="_editName" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Omschrijving</label>
                        <textarea @bind="_editDescription" rows="2" class="form-control"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Klant</label>
                        <select @bind="_editClientId" class="form-control">
                            @foreach (var c in _clients)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Startdatum</label>
                        <input type="date" @bind="_editStartDate" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select @bind="_editStatus" class="form-control">
                            <option value="Active">Actief</option>
                            <option value="Inactive">Inactief</option>
                        </select>
                    </div>
                    <div style="display:flex;gap:8px;">
                        <button class="btn btn-primary" style="flex:1;" @onclick="() => SaveEdit(project)" disabled="@_saving">
                            @(_saving ? "Opslaan..." : "Opslaan")
                        </button>
                        <button class="btn btn-secondary" style="flex:1;" @onclick="CancelEdit">Annuleren</button>
                    </div>
                }
                else
                {
                    <div class="list-item-row">
                        <span class="item-title">@project.Name</span>
                        <span class="badge @(project.Status == "Active" ? "badge-success" : "badge-pending")">
                            @(project.Status == "Active" ? "Actief" : "Inactief")
                        </span>
                    </div>
                    <p class="item-sub" style="margin-top:6px;">@project.Description</p>
                    <p class="item-sub">Klant: @(client?.Name ?? "Onbekend")</p>
                    <p class="item-sub">Start: @project.StartDate.ToString("dd/MM/yyyy")</p>

                    @if (_isAdmin)
                    {
                        @if (_confirmDeleteId == project.Id)
                        {
                            <div style="display:flex;gap:8px;margin-top:10px;">
                                <button class="btn" style="flex:1;background:#e74c3c;color:white;font-size:13px;padding:7px;"
                                        @onclick="() => DeleteProject(project.Id)" disabled="@_saving">
                                    Ja, verwijderen
                                </button>
                                <button class="btn btn-secondary" style="flex:1;font-size:13px;padding:7px;"
                                        @onclick="() => _confirmDeleteId = -1">Annuleren</button>
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;gap:8px;margin-top:10px;">
                                <button class="btn btn-primary" style="flex:1;font-size:13px;padding:7px;"
                                        @onclick="() => StartEdit(project)">Bewerken</button>
                                <button class="btn btn-danger" style="flex:1;font-size:13px;padding:7px;"
                                        @onclick="() => _confirmDeleteId = project.Id">Verwijderen</button>
                            </div>
                        }
                    }
                }
            </div>
        }
    }
</div>

@code {
    private List<Project> _projects = new();
    private List<Client> _clients = new();
    private bool _loading = true;
    private bool _isAdmin;
    private bool _saving;
    private string _message = "";
    private bool _isError;

    // Aanmaken
    private string _newName = "";
    private string _newDescription = "";
    private int _newClientId;
    private DateTime _newStartDate = DateTime.Today;

    // Bewerken
    private int _editingId = -1;
    private string _editName = "";
    private string _editDescription = "";
    private int _editClientId;
    private DateTime _editStartDate;
    private string _editStatus = "Active";

    // Verwijderen
    private int _confirmDeleteId = -1;

    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        var user = UserService.GetCurrentUser();
        if (user == null) { Nav.NavigateTo("/login"); return; }
        _isAdmin = UserService.IsCurrentUserAdmin();
        await LoadDataAsync();
        _loading = false;
        _ = StartPollingAsync();
    }

    private async Task LoadDataAsync()
    {
        _projects = await ProjectService.GetAllProjectsAsync();
        _clients = await ClientService.GetAllClientsAsync();
    }

    private async Task CreateProject()
    {
        if (string.IsNullOrWhiteSpace(_newName)) { _message = "Voer een projectnaam in."; _isError = true; return; }
        if (_newClientId == 0) { _message = "Selecteer een klant."; _isError = true; return; }

        _saving = true;
        await ProjectService.CreateProjectAsync(new Project
        {
            Name = _newName,
            Description = _newDescription,
            ClientId = _newClientId,
            StartDate = _newStartDate,
            Status = "Active"
        });
        _projects = await ProjectService.GetAllProjectsAsync();
        _message = "Project aangemaakt!";
        _isError = false;
        _newName = "";
        _newDescription = "";
        _newClientId = 0;
        _newStartDate = DateTime.Today;
        _saving = false;
    }

    private void StartEdit(Project p)
    {
        _editingId = p.Id;
        _editName = p.Name;
        _editDescription = p.Description;
        _editClientId = p.ClientId;
        _editStartDate = p.StartDate;
        _editStatus = p.Status;
        _confirmDeleteId = -1;
    }

    private void CancelEdit()
    {
        _editingId = -1;
    }

    private async Task SaveEdit(Project project)
    {
        if (string.IsNullOrWhiteSpace(_editName)) { _message = "Projectnaam mag niet leeg zijn."; _isError = true; return; }

        _saving = true;
        project.Name = _editName;
        project.Description = _editDescription;
        project.ClientId = _editClientId;
        project.StartDate = _editStartDate;
        project.Status = _editStatus;
        await ProjectService.UpdateProjectAsync(project);
        _projects = await ProjectService.GetAllProjectsAsync();
        _editingId = -1;
        _message = "Project opgeslagen!";
        _isError = false;
        _saving = false;
    }

    private async Task DeleteProject(int id)
    {
        _saving = true;
        await ProjectService.DeleteProjectAsync(id);
        _projects = await ProjectService.GetAllProjectsAsync();
        _confirmDeleteId = -1;
        _message = "Project verwijderd.";
        _isError = false;
        _saving = false;
    }

    private async Task StartPollingAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                if (_saving || _editingId != -1) continue;
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
