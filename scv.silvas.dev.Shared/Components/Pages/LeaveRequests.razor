@page "/leave"
@using scv.silvas.dev.Shared.Models
@using scv.silvas.dev.Shared.Services
@inject LeaveRequestService LeaveRequestService
@inject UserService UserService
@inject NavigationManager Nav
@implements IDisposable

<div class="page-container">
    <div class="page-header">
        <h2>Verlofaanvragen</h2>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")">@_message</div>
    }

    @if (_isAdmin)
    {
        <h3 class="section-title" style="margin-top:0;">Openstaande aanvragen — beheer</h3>
        <div class="card">
            @if (!_pendingAll.Any())
            {
                <p class="empty-text">Geen openstaande aanvragen</p>
            }
            @foreach (var req in _pendingAll)
            {
                <div class="list-item">
                    <div class="list-item-row">
                        <span class="item-title">@(req.User?.FullName ?? "Onbekend")</span>
                        <span class="badge">@req.LeaveType</span>
                    </div>
                    <div class="item-sub">@req.Reason</div>
                    <div class="item-sub">@req.StartDate.ToString("dd/MM") – @req.EndDate.ToString("dd/MM/yyyy") (@req.GetTotalDays() dagen)</div>
                    <div style="display:flex;gap:8px;margin-top:10px;align-items:center;flex-wrap:wrap;">
                        <button class="btn btn-primary" style="padding:7px 16px;font-size:13px;"
                                @onclick="() => Approve(req.Id)" disabled="@_processing">
                            Goedkeuren
                        </button>
                        <input type="text" class="form-control" style="flex:1;min-width:120px;padding:7px 10px;font-size:13px;"
                               placeholder="Reden weigering..."
                               value="@_rejectionReasons.GetValueOrDefault(req.Id, string.Empty)"
                               @onchange="@(e => _rejectionReasons[req.Id] = e.Value?.ToString() ?? string.Empty)"  />
                        <button class="btn" style="padding:7px 16px;font-size:13px;background:#e74c3c;color:white;"
                                @onclick="() => Reject(req.Id)" disabled="@_processing">
                            Weigeren
                        </button>
                    </div>
                    <div class="divider"></div>
                </div>
            }
        </div>
    }

    <h3 class="section-title" style="@(_isAdmin ? "" : "margin-top:0;")">Nieuwe aanvraag</h3>
    <div class="card form-card">
        <div class="form-group">
            <label>Type verlof</label>
            <select @bind="_leaveType" class="form-control">
                <option value="Vacation">Vakantie</option>
                <option value="Sick">Ziek</option>
                <option value="Personal">Persoonlijk</option>
                <option value="Other">Overig</option>
            </select>
        </div>
        <div class="form-group">
            <label>Startdatum</label>
            <input type="date" @bind="_startDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>Einddatum</label>
            <input type="date" @bind="_endDate" class="form-control" />
        </div>
        <div class="form-group">
            <label>Reden</label>
            <textarea @bind="_reason" rows="3" class="form-control" placeholder="Beschrijf de reden..."></textarea>
        </div>
        <button class="btn btn-primary btn-full" @onclick="Submit" disabled="@_saving">
            @(_saving ? "Indienen..." : "Aanvraag indienen")
        </button>
    </div>

    <h3 class="section-title">Mijn aanvragen</h3>
    <div class="card">
        @if (!_requests.Any())
        {
            <p class="empty-text">Geen verlofaanvragen</p>
        }
        @foreach (var req in _requests.OrderByDescending(r => r.CreatedAt))
        {
            <div class="list-item">
                <div class="list-item-row">
                    <span class="item-title">@req.Reason</span>
                    <span class="item-value @StatusColor(req.Status)">@StatusLabel(req.Status)</span>
                </div>
                <div class="list-item-row">
                    <span class="item-sub">@req.StartDate.ToString("dd/MM") – @req.EndDate.ToString("dd/MM/yyyy") (@req.GetTotalDays() dagen)</span>
                    <span class="badge">@req.LeaveType</span>
                </div>
                @if (!string.IsNullOrEmpty(req.RejectionReason))
                {
                    <div class="item-sub" style="color:#c0392b;margin-top:4px;">Reden: @req.RejectionReason</div>
                }
                <div class="divider"></div>
            </div>
        }
    </div>
</div>

@code {
    private List<LeaveRequest> _requests = new();
    private List<LeaveRequest> _pendingAll = new();
    private Dictionary<int, string> _rejectionReasons = new();
    private bool _isAdmin;
    private string _leaveType = "Vacation";
    private DateTime _startDate = DateTime.Today.AddDays(1);
    private DateTime _endDate = DateTime.Today.AddDays(5);
    private string _reason = "";
    private string _message = "";
    private bool _isError;
    private bool _saving;
    private bool _processing;
    private CancellationTokenSource _cts = new();
    private int _userId;

    protected override async Task OnInitializedAsync()
    {
        var user = UserService.GetCurrentUser();
        if (user == null) { Nav.NavigateTo("/login"); return; }
        _userId = user.Id;
        _isAdmin = UserService.IsCurrentUserAdmin();
        await LoadDataAsync();
        _ = StartPollingAsync();
    }

    private async Task LoadDataAsync()
    {
        _requests = await LeaveRequestService.GetLeaveRequestsByUserAsync(_userId);
        if (_isAdmin)
        {
            _pendingAll = await LeaveRequestService.GetPendingLeaveRequestsAsync();
            foreach (var req in _pendingAll.Where(r => !_rejectionReasons.ContainsKey(r.Id)))
                _rejectionReasons[req.Id] = "";
        }
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_reason)) { _message = "Voer een reden in."; _isError = true; return; }
        if (_endDate < _startDate) { _message = "Einddatum moet na startdatum zijn."; _isError = true; return; }

        _saving = true;
        await LeaveRequestService.CreateLeaveRequestAsync(new LeaveRequest
        {
            UserId = _userId,
            LeaveType = _leaveType,
            StartDate = _startDate,
            EndDate = _endDate,
            Reason = _reason
        });
        await LoadDataAsync();
        _message = "Verlofaanvraag ingediend!";
        _isError = false;
        _reason = "";
        _saving = false;
    }

    private async Task Approve(int id)
    {
        _processing = true;
        var user = UserService.GetCurrentUser();
        await LeaveRequestService.ApproveLeaveRequestAsync(id, user?.FullName ?? "Admin");
        await LoadDataAsync();
        _message = "Verlofaanvraag goedgekeurd.";
        _isError = false;
        _processing = false;
    }

    private async Task Reject(int id)
    {
        _processing = true;
        var reason = _rejectionReasons.GetValueOrDefault(id, "");
        await LeaveRequestService.RejectLeaveRequestAsync(id, reason);
        await LoadDataAsync();
        _message = "Verlofaanvraag geweigerd.";
        _isError = false;
        _processing = false;
    }

    private async Task StartPollingAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                if (_saving || _processing) continue;
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private string StatusColor(string status) => status switch
    {
        "Approved" => "green",
        "Rejected" => "red",
        _ => "orange"
    };

    private string StatusLabel(string status) => status switch
    {
        "Approved" => "Goedgekeurd",
        "Rejected" => "Geweigerd",
        _ => "In behandeling"
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
